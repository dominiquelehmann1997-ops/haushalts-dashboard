{"nodes": [{"id": "design_haushalts_dashboard_spec", "label": "Haushalts-Dashboard Design-Spezifikation", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-07-haushalts-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "hausdash_design_doc", "label": "Haushalts-Dashboard Design-Spezifikation", "file_type": "document", "source_file": "docs/superpowers/specs/2026-06-07-haushalts-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "hausdash_fairness_engine", "label": "Verteil-Engine Fairness-Konto", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-07-haushalts-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pipeline: Personen-Filter \u2192 Wetter-Check \u2192 Kalender-Verf\u00fcgbarkeit \u2192 Fairness-Konto mit Ziel-Aufteilung; Person am weitesten hinter Zielanteil bekommt Aufgabe. Soll Mental Load reduzieren, besonders f\u00fcr Emely."}, {"id": "hausdash_elternzeit_modus", "label": "Elternzeit-/Phasen-Modus", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-07-haushalts-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fairness-Ziel passt sich an Lebensphase an (z.B. Dome 70%/Emely 30% statt 50/50), weil Betreuung echte Arbeit ist; 'zuhause' hei\u00dft nicht 'frei'. Sichtbar aber nicht besch\u00e4mend kommuniziert."}, {"id": "hausdash_nachtrag", "label": "Spontan-Nachtrag erledigter Aufgaben", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-06-07-haushalts-dashboard-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Macht unsichtbare Arbeit (auch Betreuung/Baby-A