{"nodes": [{"id": "doc_recipe_vault_import_contract", "label": "Rezept-Vault Import-Contract", "file_type": "document", "source_file": "docs/recipe-vault-import-contract.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_vault_ist_wahrheit", "label": "Vault = Wahrheit, DB = Cache", "file_type": "rationale", "source_file": "docs/recipe-vault-import-contract.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Der Importer schreibt nur .md-Dateien in den Obsidian-Vault; das Dashboard liest den Ordner per Ingest ein und spiegelt ihn in SQLite. Der Importer redet nie mit der DB, damit Vault und App-DB klar getrennte Verantwortlichkeiten bleiben und der Vault die alleinige Quelle der Wahrheit ist."}, {"id": "concept_slug_identity_anchor", "label": "Slug/id als Identit\u00e4ts-Anker", "file_type": "rationale", "source_file": "docs/recipe-vault-import-contract.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Der Upsert-Key ist der Slug (frontmatter.id oder abgeleitet aus Dateiname). Er darf nie ge\u00e4ndert werden, da ein ge\u00e4nderter Slug beim n\u00e4chsten Ingest ein neues Rezept erzeugt und das alte archived=true (Soft-Delete) wird, wodurch die Plan-Historie ins Leere zeigt."}, {"id": "concept_orphan_archivierung", "label": "Orphan-Archivierung statt L\u00f6schung", "file_type": "rationale", "source_file": "docs/recipe-vault-import-contract.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Vault-Rezepte, deren Slug beim Ingest nicht mehr auftaucht, werden archived=true statt gel\u00f6scht; ein leerer Vault archiviert nichts, als Schutz vor Total-Archivierung."}], "edges": [{"source": "doc_recipe_vault_import_contract", "target": "recipeIngest_ingestVault", "relation": "references", "