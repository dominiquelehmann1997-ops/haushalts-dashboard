# Open-Meteo (Phase 5) — free, no API key needed. Set these to your
# household's real coordinates (WGS84 lat/lon); the defaults below are
# Berlin's and only meant as placeholders.
WEATHER_LAT=52.52
WEATHER_LON=13.41

# Pfad zum Obsidian-Rezepte-Vault (lokal gesyncte Kopie), gelesen von "Rezepte einlesen"
RECIPE_VAULT_PATH="C:/Users/<user>/Obsidian/Haushalt/Rezepte"
