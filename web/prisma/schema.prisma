// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// SQLite has no native enum type — string columns are used for enum-like
// fields. Allowed values are documented per field below.

/// Household member. key values: "dome" | "emely" | "baby"
model Person {
  id          String @id @default(cuid())
  key         String @unique // "dome" | "emely" | "baby"
  name        String
  colorAccent String
  role        String // "adult" | "baby"

  assignedTasks  Task[]
  accountEntries AccountEntry[]
}

/// A task / routine / shopping / project item.
model Task {
  id               String  @id @default(cuid())
  title            String
  type             String // "routine" | "todo" | "shopping" | "project"
  effort           Int
  rhythm           String? // e.g. "weekly", "2x-week"
  allowedPersons   String // "both" | "dome" | "emely"
  outdoor          Boolean @default(false)
  weatherCondition String? // JSON string: {noRain:bool, minTemp?:number}
  status           String  @default("open") // "open" | "done" | "moved" | "failed"
  reason           String?
  icon             String?
  note             String?
  sub              String?

  assignedToId String?
  assignedTo   Person? @relation(fields: [assignedToId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  // id of the routine Task this instance was generated from (Phase 3 recurrence).
  // Intentionally a bare scalar, not a self-relation, to keep recurring chains simple.
  recurringParentId String?

  dueDate     DateTime
  completedAt DateTime?
  createdAt   DateTime @default(now())

  accountEntries AccountEntry[]
}

/// Grouping of related tasks.
model Project {
  id    String  @id @default(cuid())
  title String
  icon  String?

  tasks Task[]
}

/// Synced calendar event (e.g. from Google Calendar).
model CalendarEvent {
  id          String   @id @default(cuid())
  externalId  String   @unique
  calendarKey String
  title       String
  start       DateTime
  end         DateTime
  personKey   String? // "dome" | "emely" | "baby"
  kind        String   @default("termin") // "termin" | "baby-arzt"
  place       String?
  updatedAt   DateTime @updatedAt
}

/// A points-based ledger entry for a person's "Konto".
model AccountEntry {
  id String @id @default(cuid())

  personId String
  person   Person @relation(fields: [personId], references: [id])

  label  String
  points Int
  source String // "planned" | "nachtrag" | "betreuung"

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id])

  occurredAt DateTime @default(now())
}

/// Time-bound configuration for "normal" vs "Elternzeit" mode.
model PhaseSetting {
  id           String    @id @default(cuid())
  mode         String // "normal" | "elternzeit"
  targetDome   Int
  targetEmely  Int
  caregiverKey String? // "dome" | "emely" | "baby"
  activeFrom   DateTime
  activeUntil  DateTime?
  isActive     Boolean   @default(true)
}

/// A recipe used for meal planning.
model Recipe {
  id         String  @id @default(cuid())
  name       String
  simple     Boolean @default(true)
  reheatable Boolean @default(false)
  tags       String? // JSON string array
  rating     String  @default("ok") // "favorit" | "ok" | "selten" (aus Vault-Frontmatter; Feature A)
  slug       String? @unique // stabiler Vault-Anker (Frontmatter `id`); null für Nicht-Vault-Rezepte
  archived   Boolean @default(false) // true, wenn das Rezept nicht mehr im Vault liegt

  ingredients     Ingredient[]
  mealPlanEntries MealPlanEntry[]
}

/// A single ingredient line of a recipe.
model Ingredient {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  name     String
  amount   String?
  unit     String?
  category String? // "frisch" | "haltbar" — explizite Angabe (Vault-Frontmatter); null → Override/Heuristik beim Lesen
}

/// A planned meal for a given date.
model MealPlanEntry {
  id           String   @id @default(cuid())
  date         DateTime
  reason       String? // "emely-allein" | "aufwaermen-extra" | null
  extraPortion Boolean  @default(false)
  status       String   @default("active") // "active" | "draft"

  // recipeId nullable → ein Tag kann bewusst "frei" (übersprungen) sein.
  recipeId String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id])
}

/// A shopping list item.
model ShoppingItem {
  id        String   @id @default(cuid())
  text      String
  meal      Boolean  @default(false)
  source    String   @default("manual") // "manual" | "recipe"
  recipeRef String?
  category  String? // "frisch" | "haltbar" für Rezept-Items; null für manuelle
  spec      String? // zusammengefasste Mengenangabe (z.B. "500 g") für Bring; null = keine Menge
  pushed    Boolean  @default(false) // schon auf Bring? (nur Rezept-Items)
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
}

/// A pinned/dated note.
model Note {
  id     String    @id @default(cuid())
  icon   String?
  text   String
  pinned Boolean   @default(false)
  date   DateTime?
}

/// Stored OAuth credentials for a third-party provider (Phase 4: Google Calendar,
/// read-only). Only the refresh token is required to stay "connected" across
/// restarts; access token + expiry are cached opportunistically.
model OAuthToken {
  id           String    @id @default(cuid())
  provider     String    @unique // "google"
  refreshToken String
  accessToken  String?
  expiresAt    DateTime?
  updatedAt    DateTime  @updatedAt
}

/// Gelernte Haltbarkeits-Korrektur (Sanftes Lernen C1): einmal am Einkaufs-Item
/// korrigiert, gilt der Wert für jedes künftige Auftauchen der Zutat.
model FreshnessOverride {
  id        String @id @default(cuid())
  name      String @unique // normalisierter Zutatenname (trim + lowercase)
  freshness String // "frisch" | "haltbar"
}

model PushSubscription {
  id        String   @id @default(cuid())
  personKey String // "dome" | "emely"
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
